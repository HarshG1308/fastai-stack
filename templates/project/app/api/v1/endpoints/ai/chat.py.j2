from fastapi import APIRouter, HTTPException
from pydantic import BaseModel
from sse_starlette.sse import EventSourceResponse

from app.core.config import settings

router = APIRouter()


class ChatRequest(BaseModel):
    message: str


@router.post("/chat")
async def chat(request: ChatRequest):
{% if config.ai.value == 'openai' %}
    if not settings.openai_api_key:
        raise HTTPException(status_code=400, detail="OPENAI_API_KEY is not configured")

    from openai import AsyncOpenAI

    client = AsyncOpenAI(api_key=settings.openai_api_key)
    stream = await client.chat.completions.create(
        model="gpt-4o-mini",
        messages=[{"role": "user", "content": request.message}],
        stream=True,
    )

    async def event_publisher():
        async for chunk in stream:
            delta = chunk.choices[0].delta.content or ""
            if delta:
                yield {"event": "token", "data": delta}
        yield {"event": "done", "data": "[DONE]"}

    return EventSourceResponse(event_publisher())
{% elif config.ai.value == 'langchain' %}
    return {"response": f"LangChain template wired. Prompt: {request.message}"}
{% elif config.ai.value == 'huggingface' %}
    return {"response": f"HuggingFace template wired. Prompt: {request.message}"}
{% else %}
    raise HTTPException(status_code=400, detail="AI integration not enabled")
{% endif %}
